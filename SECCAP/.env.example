# =============================================================================
# SECCAP - Variables de Entorno
# =============================================================================
# Copiar este archivo como .env en la raíz de SECCAP/ y ajustar los valores.
# NO commitear el archivo .env real.

# --- General ---
NODE_ENV=development

# --- Backend Proxy ---
BACKEND_PORT=3001
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# --- Mock API ---
MOCK_API_PORT=3002
MOCK_API_URL=http://localhost:3002

# --- PostgreSQL (BD local) ---
DATABASE_URL=postgresql://seccap:seccap_dev@localhost:5432/seccap_dev

# --- Autenticación ---
JWT_SECRET=CAMBIAR_EN_PRODUCCION_clave_segura_minimo_32_chars
JWT_EXPIRES_IN=8h
